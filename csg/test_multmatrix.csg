// test_multmatrix.csg  -  multmatrix esplicita (come da export OpenSCAD)
// Stesso effetto di translate + scale, ma fatto a mano.
group() {
    multmatrix([[1.5, 0, 0, -1.0],
                [0, 1.5, 0,  0.0],
                [0, 0, 1.5,  0.0],
                [0, 0, 0,    1.0]]) {
        color([0.80, 0.35, 0.45, 1]) sphere(r = 1);
    }
    multmatrix([[1, 0, 0,  1.5],
                [0, 1, 0,  0.0],
                [0, 0, 1, -0.5],
                [0, 0, 0,  1.0]]) {
        color([0.45, 0.65, 0.80, 1]) cube(size = [1, 1, 1], center = false);
    }
}
